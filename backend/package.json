{
  "name": "primeloop-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:db": "TEST_DATABASE_URL=postgresql://primeloop:primeloop_test@localhost:55433/primeloop_test vitest run",
    "test:db:up": "docker compose -f ../docker-compose.test.yml up -d postgres-test",
    "test:db:down": "docker compose -f ../docker-compose.test.yml down -v",
    "test:db:docker": "docker build -t primeloop-backend-test -f Dockerfile.test . && docker run --rm --network primeloop_default -e TEST_DATABASE_URL=postgresql://primeloop:primeloop_test@postgres-test:5432/primeloop_test primeloop-backend-test npm test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.12.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@slack/bolt": "^4.7.1",
    "axios": "^1.17.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "pg": "^8.13.0",
    "pi-acp": "^0.0.27",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/ssh2": "^1.15.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "lodash": "^4.18.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
