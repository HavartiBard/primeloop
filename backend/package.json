{
  "name": "agent-control-plane-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:db": "TEST_DATABASE_URL=postgresql://agent_cp:agent_cp_test@localhost:55432/agent_cp_test vitest run",
    "test:db:up": "docker compose -f ../docker-compose.test.yml up -d postgres-test",
    "test:db:down": "docker compose -f ../docker-compose.test.yml down -v",
    "test:db:docker": "docker build -t agent-cp-backend-test -f Dockerfile.test . && docker run --rm --network agent-control-plane_default -e TEST_DATABASE_URL=postgresql://agent_cp:agent_cp_test@postgres-test:5432/agent_cp_test agent-cp-backend-test npm test"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.1",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/ssh2": "^1.15.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
