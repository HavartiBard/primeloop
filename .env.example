# Required
POSTGRES_PASSWORD=changeme
# 64-char hex key that encrypts stored secrets — generate with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=
# Access token for the dashboard/API — install.sh generates one. Sign in with
# it in the browser, or send it as "Authorization: Bearer <token>" from scripts.
# Leaving it empty disables authentication entirely (NOT recommended).
PRIMELOOP_ADMIN_TOKEN=

# ───────────────────────────────────────────────────────────────────────────────
# Production image + storage (docker-compose.prod.yml only)
# ───────────────────────────────────────────────────────────────────────────────
# Published PrimeLoop image to run. Required by docker-compose.prod.yml;
# ignored by docker-compose.yml, which builds from source.
#   PRIMELOOP_IMAGE=ghcr.io/<owner>/primeloop:latest
PRIMELOOP_IMAGE=
# Host directory for all durable state (Postgres data, workspace, catalog).
# Defaults to ./data next to the compose file.
PRIMELOOP_DATA_DIR=
# Host port for the dashboard/API (default 3100)
PRIMELOOP_PORT=

# ───────────────────────────────────────────────────────────────────────────────
# CORS Origins (only needed when the dashboard is served from a different origin)
# ───────────────────────────────────────────────────────────────────────────────
# The bundled dashboard is same-origin with the API, so most installs can leave
# this empty. Set it when a separate frontend (e.g. the Vite dev server) calls
# the API cross-origin. Comma-separated, no trailing slashes.
#
# Example:
#   PRIMELOOP_CORS_ORIGINS=http://localhost:5173,http://my-dev-box:5173
#
PRIMELOOP_CORS_ORIGINS=

# Optional LangGraph integration
LANGGRAPH_API_URL=

# Optional Slack notifications
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Optional local LLM bootstrap for setup/runtime
# Set LOCAL_LLM_BASE_URL directly, set LOCAL_LLM_HOST and let PrimeLoop probe
# common ports, or just set LOCAL_LLM_ENABLED=1 to autodiscover a server on
# this machine (probes host.docker.internal, then localhost).
# Types: ollama, llamacpp, litellm, vllm, lmstudio, llm-proxy, auto
LOCAL_LLM_ENABLED=0
LOCAL_LLM_TYPE=auto
LOCAL_LLM_BASE_URL=
LOCAL_LLM_HOST=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=
LOCAL_LLM_NAME=local-env

# Optional: legacy dev-only UI prefill for the Vite frontend
VITE_LOCAL_AI_BASE_URL=

# Optional cloud LLM provider keys (not needed if you configure a local provider in setup)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: managed-agent runtime flags (Spec 024) — all default OFF.
# If CREDENTIAL_BROKER=1, also set CONTROL_PLANE_URL so Prime can reach the LLM proxy.
# RESUME_ON_RESTART=0
# LAZY_PROVISIONING=0
# CREDENTIAL_BROKER=0
# EGRESS_SANDBOX=0
# CONTROL_PLANE_URL=http://127.0.0.1:3100

# Fleet executor
AGENT_REPO_ROOT=/workspace/repo
AGENT_WORKTREE_ROOT=/workspace/agents

# Optional: Gitea integration for work tracking
GITEA_TOKEN=

# ───────────────────────────────────────────────────────────────────────────────
# Catalog Storage (required for production)
# ───────────────────────────────────────────────────────────────────────────────
# The catalog YAML directory must be durable storage — volume-mounted in the
# container. Changes to agent templates require:
#   1. Edit YAML files in the mounted volume (or via Git sync)
#   2. POST /api/catalog/sync to register new versions
#   3. Approval via catalog state machine before use
#
# Two supported modes:
#
#   MODE 1: Local volume mount (recommended for single-host installs)
#     - docker-compose.prod.yml mounts ${PRIMELOOP_DATA_DIR:-./data}/catalog
#       to /app/catalog — no env vars needed
#     - The container only reads it; you may add :ro to the mount in this mode
#
#   MODE 2: Git source (recommended for multi-host/CI workflows)
#     - Set CATALOG_SOURCE_TYPE=git
#     - Set CATALOG_GIT_URL=https://...
#     - Set CATALOG_GIT_REF=main (or tag/commit)
#     - Container clones/pulls into /app/catalog on startup, so the
#       mount must be read-write in this mode
#
CATALOG_SOURCE_TYPE=local  # 'local' or 'git'
CATALOG_GIT_URL=           # Required if CATALOG_SOURCE_TYPE=git (HTTPS URL)
CATALOG_GIT_REF=main       # Branch/tag/commit for Git source
CATALOG_GIT_TOKEN=         # PAT with repo scope (required for private repos)

# Workspace Git sync (auto-backup operator-authored content to catalog repo)
# Set to 0 to disable auto-sync (manual control only)
# Default: 3600 (1 hour)
WORKSPACE_SYNC_INTERVAL=3600
