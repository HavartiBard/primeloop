# Required
POSTGRES_PASSWORD=changeme
# 64-char hex key that encrypts stored secrets — generate with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=
# Optional LangGraph integration
LANGGRAPH_API_URL=http://192.168.20.14:8000

# Optional — defaults shown
RACLETTE_API_URL=http://192.168.20.169:9119
RACLETTE_SESSION_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=C0AU0620ATX
# Optional local LLM bootstrap for setup/runtime
# Set LOCAL_LLM_BASE_URL directly, or set LOCAL_LLM_HOST and let PrimeLoop probe common ports.
# Types: ollama, llamacpp, litellm, vllm, lmstudio, llm-proxy, auto
LOCAL_LLM_ENABLED=0
LOCAL_LLM_TYPE=auto
LOCAL_LLM_BASE_URL=
LOCAL_LLM_HOST=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=
LOCAL_LLM_NAME=local-env

# Optional: legacy dev-only UI prefill for the Vite frontend
VITE_LOCAL_AI_BASE_URL=

# Optional cloud LLM provider keys (not needed if you configure a local provider in setup)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: managed-agent runtime flags (Spec 024) — all default OFF.
# If CREDENTIAL_BROKER=1, also set CONTROL_PLANE_URL so Prime can reach the LLM proxy.
# RESUME_ON_RESTART=0
# LAZY_PROVISIONING=0
# CREDENTIAL_BROKER=0
# EGRESS_SANDBOX=0
# CONTROL_PLANE_URL=http://127.0.0.1:3100

# Fleet executor
AGENT_REPO_ROOT=/workspace/repo
AGENT_WORKTREE_ROOT=/workspace/agents

# Optional: Gitea integration for work tracking
GITEA_TOKEN=
